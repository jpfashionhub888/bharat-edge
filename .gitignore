venv/
env/
__pycache__/
*.pyc
*.pyo
*.csv
daily_report.txt
backtest_output.txt

# ── Secrets & credentials (NEVER commit these) ────────────────
.env
.env.*
config/secrets.env
zerodha.txt
phase9_zerodha.txt
*_secrets.*
secrets.*

# ── Logs — portfolio state stays LOCAL ONLY, never committed ──
# bharat_trades.json and closed_trades.json are managed by the
# local paper trader. Committing them from GitHub Actions would
# reset the portfolio on every run.
logs/bharat_trades.json
logs/closed_trades.json
logs/*.log
logs/*.txt
# Allow scan signals and circuit breaker (written by Actions)
!logs/scan_results.json
!logs/circuit_breaker.json
!logs/bot_control.json

# ── Model/data artifacts ──────────────────────────────────────
saved_models/*.pkl
data/raw/
*.h5

# ── IDE & OS ──────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db